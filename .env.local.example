NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Shared Azure OpenAI resource (used by GPT-4o chat + embedding, and as fallback for Whisper/TTS)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=chat-prod
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# Whisper (STT) — optional overrides if Whisper lives in a different Azure resource
AZURE_OPENAI_WHISPER_ENDPOINT=
AZURE_OPENAI_WHISPER_API_KEY=
AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper-1

# TTS — optional overrides if TTS lives in a different Azure resource
AZURE_OPENAI_TTS_ENDPOINT=
AZURE_OPENAI_TTS_API_KEY=
AZURE_OPENAI_TTS_DEPLOYMENT=tts-1

RESEND_API_KEY=
EMAIL_FROM=noreply@chodex.se
EMAIL_TO=mohammed.a.haidari@gmail.com
